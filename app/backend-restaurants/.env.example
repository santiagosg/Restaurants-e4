# Database
DATABASE_URL="postgresql://restaurants_user:restaurants_password@localhost:5432/restaurants_db?schema=public"

# Application
PORT=3000
NODE_ENV=development

# JWT (Para autenticación - pendiente implementar)
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d

# Email (Para servicios de email - pendiente implementar)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# Storage (Para servicios de almacenamiento - pendiente implementar)
# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# Cloudinary (Alternativa para imágenes)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
